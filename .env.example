# ── Banco de dados (compartilhado por backend e bot do Telegram) ─────────────
POSTGRES_USER=dailyflow
POSTGRES_PASSWORD=dailyflow
POSTGRES_DB=dailyflow
# String usada pelo backend (host "postgres" = nome do serviço no compose)
DATABASE_URL=postgresql+psycopg2://dailyflow:dailyflow@postgres:5432/dailyflow

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
FRONTEND_URL=http://localhost:5173

# SMTP (opcional em dev — sem isso, e-mails de recuperação de senha são logados no console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@dailyflow.app

# ── Bot do Telegram (preenchido na Fase 3 — crie o seu via @BotFather) ───────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
